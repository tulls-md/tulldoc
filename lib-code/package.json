  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@tulls-md/tulldoc": "workspace:*",
    "clsx": "^2.1.1",
    "server-only": "^0.0.1",
    "typescript": "^5"
  },
  "peerDependencies": {
    "next": ">=16",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@babel/types": "^7.29.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  }
}
