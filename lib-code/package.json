{
  "name": "@tulls-md/tulldoc-code",
  "private": false,
  "version": "0.2.3",
  "description": "Аддон для @tulls-md/tulldoc: документирование React-компонентов из исходного кода (таблицы пропсов, автопримеры, .doc.tsx)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tulls-md/tulldoc.git",
    "directory": "lib-code"
  },
  "keywords": [
    "documentation",
    "nextjs",
    "react",
    "mdx",
    "component-library",
    "docs-generator",
    "props-table",
    "tulldoc"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./styles.css": "./dist/tulldoc-code.css",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@tulls-md/tulldoc": "workspace:*",
    "clsx": "^2.1.1",
    "server-only": "^0.0.1",
    "typescript": "^5"
  },
  "peerDependencies": {
    "next": ">=16",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@babel/types": "^7.29.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "rollup-plugin-node-externals": "^9.0.1",
    "rollup-preserve-directives": "^1.1.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  }
}
