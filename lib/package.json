{
  "name": "@tulls-md/tulldoc",
  "private": false,
  "version": "0.2.0",
  "description": "Библиотека для быстрого создания сайтов документации компонентных библиотек на базе Next.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tulls-md/tulldoc.git",
    "directory": "lib"
  },
  "keywords": [
    "documentation",
    "nextjs",
    "react",
    "mdx",
    "component-library",
    "docs-generator"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "default": "./dist/config.js"
    },
    "./styles.css": "./dist/tulldoc.css",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@fontsource/golos-text": "^5.2.8",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.7",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "server-only": "^0.0.1",
    "shiki": "^4.2.0"
  },
  "peerDependencies": {
    "next": ">=16",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "rollup-plugin-node-externals": "^9.0.1",
    "rollup-preserve-directives": "^1.1.3",
    "typescript": "^5",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  }
}
