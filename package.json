{
  "name": "tulldoc-monorepo",
  "private": true,
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "build:lib": "pnpm --filter @tulls-md/tulldoc build",
    "build:lib-code": "pnpm --filter @tulls-md/tulldoc-code build",
    "build:libs": "pnpm build:lib && pnpm build:lib-code",
    "tulldoc:docs": "pnpm --filter documentation dev",
    "tulldoc:example": "pnpm --filter example dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm build:libs && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "prettier": "^3.8.3"
  }
}
